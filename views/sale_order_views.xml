<odoo>

    <record id="view_sale_order_form_payment" model="ir.ui.view">
        <field name="name">sale.order.payment.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button name="action_generate_payment"
                        string="Generate Payment"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'sale'"/>
                <button name="action_send_whatsapp"
                        string="Send WhatsApp"
                        type="object"
                        class="btn-success"
                        invisible="not payment_link"/>

            </xpath>

        </field>
    </record>

</odoo>